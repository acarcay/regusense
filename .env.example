# =============================================================================
# ReguSense — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your actual credentials
#

# =============================================================================
# Docker Compose (used only by docker-compose.yml for container bootstrap)
# =============================================================================
POSTGRES_USER=regusense
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=regusense
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# Neo4j (Graph Database)
# =============================================================================
REGUSENSE_NEO4J_URI=bolt://localhost:7687
REGUSENSE_NEO4J_USER=neo4j
REGUSENSE_NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# PostgreSQL (Relational Database)
# =============================================================================
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
REGUSENSE_DATABASE_URL=postgresql+asyncpg://regusense:your_postgres_password_here@localhost:5432/regusense

# =============================================================================
# Google Gemini AI
# =============================================================================
REGUSENSE_GEMINI_API_KEY=your_gemini_api_key_here
REGUSENSE_GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# API Authentication
# =============================================================================
# Clients must send this value in the X-API-Key header.
# Leaving it empty DISABLES auth (development only — never in production).
REGUSENSE_API_AUTH_KEY=generate_a_long_random_secret_here

# CORS — comma-separated JSON list of allowed origins (defaults to localhost)
# REGUSENSE_CORS_ORIGINS=["https://dashboard.example.com"]

# =============================================================================
# Redis / Celery (optional — defaults shown)
# =============================================================================
# REGUSENSE_REDIS_URL=redis://localhost:6379/0
# REGUSENSE_CELERY_BROKER_URL=redis://localhost:6379/0
# REGUSENSE_CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Tavily Web Search (optional)
# =============================================================================
REGUSENSE_TAVILY_API_KEY=

# =============================================================================
# Browser / Scraper Settings (optional — defaults shown)
# =============================================================================
REGUSENSE_HEADLESS=true
REGUSENSE_RETRY_ATTEMPTS=3
REGUSENSE_PAGE_TIMEOUT_MS=30000
